{
  "name": "ims-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node ./scripts/validate-env.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint && npm run lint:units",
    "lint:units": "node ./scripts/check-no-px-literals.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "workload:generate": "node ./scripts/generate-workload.mjs",
    "workload:check": "node ./scripts/check-reports.mjs",
    "workload:run": "npm run workload:generate && npm run workload:check"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "clsx": "^2.1.1",
    "jsbarcode": "^3.12.3",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/env": "^16.1.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
